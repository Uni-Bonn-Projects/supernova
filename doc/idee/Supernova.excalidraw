    {
      "id": "4eRxOY0ZbMNdiZO28qpDI",
      "type": "text",
      "x": -460.6557973225945,
      "y": -726.587291393962,
      "width": 6937.853715831624,
      "height": 229.58328247070298,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "bGD",
      "roundness": null,
      "seed": 179730517,
      "version": 512,
      "versionNonce": 402437727,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780688565836,
      "link": null,
      "locked": false,
      "text": "Ein Fremdes Riesenraumschiff (OLD MAN) kommt in ein Sonnensystem und möchte dessen Sonne zur Supernova bringen.\nWährenddessen kommen andere Schiffe um deren Sonne zu Verteidigen, jedoch sind diese zu schwach. Am Ende flüchtet OLD MAN und die Sonne explodiert. ",
      "fontSize": 91.83331298828122,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Ein Fremdes Riesenraumschiff (OLD MAN) kommt in ein Sonnensystem und möchte dessen Sonne zur Supernova bringen.\nWährenddessen kommen andere Schiffe um deren Sonne zu Verteidigen, jedoch sind diese zu schwach. Am Ende flüchtet OLD MAN und die Sonne explodiert. ",
      "autoResize": true,
      "lineHeight": 1.25
    },
