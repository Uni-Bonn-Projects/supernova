    {
      "id": "TNOPn5qA-2YREUHlUrOB4",
      "type": "text",
      "x": 7821.068154127556,
      "y": -3524.491508656931,
      "width": 4823.804742815411,
      "height": 1541.666564941408,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
