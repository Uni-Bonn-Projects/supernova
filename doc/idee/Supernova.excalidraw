      "index": "bGO",
      "roundness": null,
      "seed": 223419816,
      "version": 572,
      "versionNonce": 942872817,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1780688565836,
      "link": null,
      "locked": false,
      "text": "SCHWIERIGKEITEN:\n1. Zeit finden neben anderen Modulen \n2. Zusammenspiel boolesche Geometrie und \nalgo. Geometrie\n3. Camera Work, ordentliche implementation der Story\n4. Warten auf Teile von anderen Teammitgliedern (z.B. benötigen\nvon Raumschiffen, aber sind noch nicht da)\n5. unoptimierter Code führt zu Verlangsamung von Fortschritten",
      "fontSize": 154.16665649414077,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "SCHWIERIGKEITEN:\n1. Zeit finden neben anderen Modulen \n2. Zusammenspiel boolesche Geometrie und \nalgo. Geometrie\n3. Camera Work, ordentliche implementation der Story\n4. Warten auf Teile von anderen Teammitgliedern (z.B. benötigen\nvon Raumschiffen, aber sind noch nicht da)\n5. unoptimierter Code führt zu Verlangsamung von Fortschritten",
      "autoResize": true,
      "lineHeight": 1.25
    },
